# ASRP Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git!

# LLM API Keys
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Backup (optional)
GDRIVE_CREDENTIALS_PATH=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Communication (if using Redis)
REDIS_URL=redis://localhost:6379

# Discord notifications (optional)
DISCORD_WEBHOOK_URL=
